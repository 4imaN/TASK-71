# Never ship vendor — Composer installs inside the image
vendor/

# Git metadata not needed in the image
.git/
.gitignore

# Locally-generated bootstrap caches — artisan regenerates them during build
bootstrap/cache/packages.php
bootstrap/cache/services.php

# Env files — none should exist but exclude defensively
.env
.env.*

# Runtime artifacts
storage/logs/*.log
public/hot
public/build
node_modules/

# Editor / tool state
.idea/
.vscode/
.fleet/
.nova/
.zed/
.DS_Store
*.swp

# Test artefacts
.phpunit.cache/
.phpunit.result.cache
coverage/
