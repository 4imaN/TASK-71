{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ESNext", "DOM"],
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "playwright.config.ts",
    "helpers.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test-results",
    "dist"
  ]
}
